{
  "name": "jyowo-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "routes:generate": "tsr generate",
    "build": "pnpm routes:generate && tsc --noEmit --pretty false && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "pnpm routes:generate && tsc --noEmit --pretty false",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "env -u FORCE_COLOR -u NO_COLOR playwright test",
    "test:e2e:storybook": "env -u FORCE_COLOR -u NO_COLOR playwright test -c playwright.storybook.config.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm knip",
    "check:full": "pnpm --dir ../.. build:agent-supervisor-sidecar && pnpm check && pnpm build-storybook && pnpm test:e2e && pnpm test:e2e:storybook && pnpm tauri build --config src-tauri/tauri.check.conf.json",
    "tauri": "pnpm --dir ../.. build:agent-supervisor-sidecar && tauri"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.0.0",
    "i18next": "^26.3.1",
    "lucide-react": "1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "storybook": "10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
