{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "*.config.ts"
  ],
  "project": [
    ".storybook/**/*.{ts,tsx}",
    "e2e/**/*.ts",
    "src/**/*.{ts,tsx}",
    "*.ts"
  ],
  "ignore": [
    "src/generated/**"
  ],
  "ignoreDependencies": [
    "json-schema-to-typescript",
    "tailwindcss"
  ]
}
