{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Jyowo",
  "version": "0.1.0",
  "identifier": "com.goyacj.jyowo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Jyowo",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "devCsp": "default-src 'self' http://127.0.0.1:5173; connect-src ipc: http://ipc.localhost http://127.0.0.1:5173 ws://127.0.0.1:5173; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:5173; style-src 'self' 'unsafe-inline' http://127.0.0.1:5173; img-src 'self' data: asset: http://asset.localhost http://127.0.0.1:5173"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "binaries/jyowo-harness-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ0MjI5RDA2N0E4ODVEQ0MKUldUTVhZaDZCcDBpUkp4bW5DKzRiMlVXeEpnQWVrWTZkb3pmYk9ENWEwM0dsL2ExM3I5UGNkelQK",
      "endpoints": [
        "https://github.com/GoyacJ/Jyowo/releases/latest/download/latest.json"
      ]
    }
  }
}
