{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "dialog:allow-open",
    "store:default",
    "updater:default",
    "process:default"
  ]
}
