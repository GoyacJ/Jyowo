{
  "name": "jyowo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm -C apps/desktop tauri dev",
    "build": "pnpm -C apps/desktop build && pnpm -C apps/desktop tauri build",
    "lint": "pnpm -C apps/desktop lint",
    "format": "pnpm -C apps/desktop format",
    "check:rust": "cargo fmt --all --check && cargo check --workspace && cargo test --workspace",
    "check:desktop": "pnpm -C apps/desktop check",
    "check:desktop:full": "pnpm -C apps/desktop check:full",
    "check": "pnpm check:desktop && pnpm check:rust",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  }
}
